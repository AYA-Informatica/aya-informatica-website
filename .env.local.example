# ── AYA Informatica — Environment Variables ──────────────────
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Fill in real values
# 3. NEVER commit .env.local — it is in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ayainformatica.tech

# ── Email / SMTP (contact form) ──────────────────────────────
# Zero-cost option: use your existing Gmail with an App Password
#
# STEP 1: Enable 2FA on your Google account (required)
# STEP 2: Go to: myaccount.google.com/apppasswords
# STEP 3: Create an app password called "AYA Website"
# STEP 4: Paste it below as SMTP_PASS
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ay.company.andy@gmail.com
SMTP_PASS=your-gmail-app-password-here
SMTP_FROM="AYA Informatica" <ay.company.andy@gmail.com>
CONTACT_TO=ay.company.andy@gmail.com

# ── Alternative SMTP providers (uncomment one if not using Gmail) ──
# Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
#
# Zoho Mail (free, custom domain):
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
#
# Resend (3,000 emails/month free — great for scaling):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=your-resend-api-key
